# ──────────────────────────────────────────────
# AI Müzik Prodüksiyon – Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayıp doldurun:
#   cp .env.example .env
# ──────────────────────────────────────────────

# GPU Kullanımı (true/false)
USE_GPU=true

# TTS Model Seçimi
# Seçenekler:
#   tts_models/multilingual/multi-dataset/xtts_v2        (en iyi kalite, klonlama)
#   tts_models/tr/common-voice/glow-tts                  (hafif Türkçe model)
TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
XTTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2

# Müzik Üretim Modeli
# Seçenekler:
#   facebook/musicgen-small    (~300MB, hızlı)
#   facebook/musicgen-medium   (~1.5GB, dengeli)
#   facebook/musicgen-large    (~3.3GB, en iyi kalite)
MUSIC_MODEL=facebook/musicgen-small

# API Sunucu Ayarları
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=false
SECRET_KEY=super-secret-key-change-me

# Dosya Yükleme Limiti (MB)
MAX_UPLOAD_MB=100

# HuggingFace Token (özel/gated modeller için)
HUGGINGFACE_TOKEN=hf_your_token_here

# Cloud Storage (isteğe bağlı)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# GCP_PROJECT_ID=
# GCP_BUCKET_NAME=
